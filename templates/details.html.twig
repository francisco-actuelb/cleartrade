{% extends "base.html.twig" %}

{% block title %}Détails des transactions - ClearTrade{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="/" class="inline-flex items-center text-sm font-medium text-brand hover:text-blue-800 mb-4 transition-colors">
            &laquo; Retour au tableau de bord
        </a>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 mb-1">
                        {{ context.insider_name }}
                        <span class="text-gray-500 font-normal text-lg">chez</span>
                        {{ context.ticker }}
                    </h1>
                    <p class="text-gray-600">{{ context.company_name }}</p>
                </div>

                <div class="text-right">
                    <div class="text-sm text-gray-500 mb-1">Date d'exécution</div>
                    <div class="text-lg font-semibold text-gray-900">{{ date|date("d/m/Y") }}</div>
                    <div class="mt-2">
                        {% if type == 'P' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Achat (P)</span>
                        {% elseif type == 'S' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">Vente (S)</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- GESTION DES ERREURS -->
    {% if error %}
        <div class="bg-red-50 text-red-800 p-4 rounded-xl mb-6 border border-red-200 shadow-sm flex items-start gap-3">
            <svg class="h-6 w-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <div>
                <h3 class="font-bold">Erreur de l'Analyse IA</h3>
                <p class="text-sm mt-1">{{ error }}</p>
            </div>
        </div>
    {% endif %}

    <!-- ENCART DU SIGNAL IA (DEEPSEEK) -->
    {% if ai_signal %}
        <div class="bg-gradient-to-br from-[#f4f0ff] to-white border border-purple-200 p-6 rounded-xl shadow-sm mb-8 relative overflow-hidden">
            <!-- Décoration de fond -->
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-purple-100 rounded-full opacity-50 blur-2xl pointer-events-none"></div>

            <div class="flex items-center justify-between mb-4 relative z-10">
                <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Analyse IA <span class="text-sm font-normal text-gray-500 ml-2">({{ ai_signal.model_version }})</span>
                </h2>

                <div class="flex gap-4">
                    <div class="text-center">
                        <div class="text-xs text-gray-500 uppercase font-semibold">Signal</div>
                        {% if ai_signal.signal_type == 'BULLISH' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-md text-sm font-bold bg-green-100 text-green-800 border border-green-200 mt-1">HAUSSIER (BULLISH)</span>
                        {% elseif ai_signal.signal_type == 'BEARISH' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-md text-sm font-bold bg-red-100 text-red-800 border border-red-200 mt-1">BAISSIER (BEARISH)</span>
                        {% else %}
                            <span class="inline-flex items-center px-3 py-1 rounded-md text-sm font-bold bg-gray-100 text-gray-800 border border-gray-200 mt-1">NEUTRE (NEUTRAL)</span>
                        {% endif %}
                    </div>

                    <div class="text-center">
                        <div class="text-xs text-gray-500 uppercase font-semibold">Confiance</div>
                        <div class="mt-1 flex items-center justify-center">
                        <span class="text-lg font-extrabold {% if ai_signal.confidence_score > 70 %}text-purple-700{% else %}text-gray-700{% endif %}">
                            {{ ai_signal.confidence_score }}%
                        </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white border border-purple-100 rounded-lg p-4 relative z-10 shadow-sm text-gray-700 leading-relaxed text-sm">
                <strong class="text-purple-800">Justification :</strong><br>
                {{ ai_signal.rationale|nl2br }}
            </div>
        </div>
    {% endif %}

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 mb-1">
                        {{ context.insider_name }}
                        <span class="text-gray-500 font-normal text-lg">chez</span>
                        {{ context.ticker }}
                    </h1>
                    <p class="text-gray-600">{{ context.company_name }}</p>
                </div>

                <div class="text-right">
                    <div class="text-sm text-gray-500 mb-1">Date d'exécution</div>
                    <div class="text-lg font-semibold text-gray-900">{{ date|date("d/m/Y") }}</div>
                    <div class="mt-2">
                        {% if type == 'P' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Achat (P)</span>
                        {% elseif type == 'S' %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">Vente (S)</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white shadow-sm border border-gray-200 rounded-xl overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
            <h2 class="text-lg font-medium text-gray-900">Détail des {{ transactions|length }} transaction(s) brute(s)</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-white">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Formulaire SEC (Accession)</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Volume (Actions)</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Prix Unitaire</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Valeur Ligne</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Analyse IA</th>
                </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                {% set totalVolume = 0 %}
                {% set totalValue = 0 %}

                {% for tx in transactions %}
                    {% set totalVolume = totalVolume + tx.shares %}
                    {% set totalValue = totalValue + (tx.shares * tx.price_per_share) %}

                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
                            <!-- CORRECTION : Utilisation de tx.sec_url générée dans le Controller -->
                            <a href="{{ tx.sec_url }}" target="_blank" class="text-brand hover:underline" title="Voir le document SEC original (Ligne {{ tx.line_index }})">
                                {{ tx.accession_number }}
                            </a>
                            <span class="text-xs text-gray-400 ml-1">(L{{ tx.line_index }})</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
                            {{ tx.shares|number_format(0, ',', ' ') }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                            ${{ tx.price_per_share|number_format(4, '.', ',') }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                            ${{ (tx.shares * tx.price_per_share)|number_format(2, '.', ' ') }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center">
                            <form method="POST" action="/analyze-detail/{{ tx.id }}">
                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-colors">
                                    <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                    Analyser
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot class="bg-gray-50 border-t border-gray-200">
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-right uppercase">Total Agrégé</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-right">
                        {{ totalVolume|number_format(0, ',', ' ') }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-right">
                        ${{ (totalValue / totalVolume)|number_format(4, '.', ',') }} <span class="text-xs text-gray-500 font-normal">(Moyen)</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-right text-brand flex justify-between items-center">
                        <span>${{ totalValue|number_format(2, '.', ' ') }}</span>

                        <!-- LE BOUTON GLOBAL CONDITIONNÉ -->
                        {% if not ai_signal %}
                            <form method="POST" action="/analyze" class="ml-4 inline-block">
                                <input type="hidden" name="company_id" value="{{ context.company_id }}">
                                <input type="hidden" name="insider_id" value="{{ context.insider_id }}">
                                <input type="hidden" name="date" value="{{ date }}">
                                <input type="hidden" name="type" value="{{ type }}">
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-bold rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-colors">
                                    <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                    Analyser l'opération globale
                                </button>
                            </form>
                        {% else %}
                            <span class="ml-4 inline-flex items-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed">
                                <svg class="mr-2 h-5 w-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Analyse terminée
                            </span>
                        {% endif %}
                    </td>
                </tr>
                </tfoot>
            </table>
        </div>
    </div>
{% endblock %}