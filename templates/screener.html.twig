{% extends "base.html.twig" %}

{% block title %}Screener Hybride - ClearTrade{% endblock %}

{% block content %}
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2 flex items-center gap-3">
            <svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
            Screener Hybride
        </h1>
        <p class="text-gray-600">Filtrez les transactions selon des critères fondamentaux et analysez instantanément la technique.</p>
    </div>

    <!-- Panneau des Filtres Avancés (Maintenu en 2 colonnes comme validé) -->
    <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 mb-8">
        <form method="GET" action="/screener" class="grid grid-cols-2 gap-3 sm:gap-4 items-end w-full">

            <div class="w-full">
                <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Type d'opération</label>
                <select name="type" class="block w-full h-[42px] rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand text-xs sm:text-sm border px-2 sm:px-3 bg-white">
                    <option value="P" {% if filters.type == 'P' %}selected{% endif %}>🟢 Achats</option>
                    <option value="S" {% if filters.type == 'S' %}selected{% endif %}>🔴 Ventes</option>
                    <option value="ALL" {% if filters.type == 'ALL' %}selected{% endif %}>Tous</option>
                </select>
            </div>

            <div class="w-full">
                <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Rôle de l'initié</label>
                <select name="role" class="block w-full h-[42px] rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand text-xs sm:text-sm border px-2 sm:px-3 bg-white">
                    <option value="">Tous</option>
                    <option value="CEO" {% if filters.role == 'CEO' %}selected{% endif %}>👑 CEO</option>
                    <option value="CFO" {% if filters.role == 'CFO' %}selected{% endif %}>💰 CFO</option>
                    <option value="DIRECTOR" {% if filters.role == 'DIRECTOR' %}selected{% endif %}>👔 Director</option>
                </select>
            </div>

            <div class="w-full">
                <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Montant Min.</label>
                <select name="min_value" class="block w-full h-[42px] rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand text-xs sm:text-sm border px-2 sm:px-3 bg-white">
                    <option value="0" {% if filters.min_value == 0 %}selected{% endif %}>> 0 $</option>
                    <option value="50000" {% if filters.min_value == 50000 %}selected{% endif %}>> 50k $</option>
                    <option value="100000" {% if filters.min_value == 100000 %}selected{% endif %}>> 100k $</option>
                    <option value="500000" {% if filters.min_value == 500000 %}selected{% endif %}>> 500k $</option>
                    <option value="1000000" {% if filters.min_value == 1000000 %}selected{% endif %}>> 1M $</option>
                </select>
            </div>

            <div class="w-full">
                <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Fenêtre temporelle</label>
                <select name="days" class="block w-full h-[42px] rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand text-xs sm:text-sm border px-2 sm:px-3 bg-white">
                    <option value="7" {% if filters.days == 7 %}selected{% endif %}>7 Jours</option>
                    <option value="30" {% if filters.days == 30 %}selected{% endif %}>30 Jours</option>
                    <option value="90" {% if filters.days == 90 %}selected{% endif %}>90 Jours</option>
                </select>
            </div>

            <div class="w-full col-span-2 flex gap-2 pt-2">
                <button type="submit" class="flex-1 h-[42px] inline-flex justify-center items-center px-4 border border-transparent text-sm font-bold rounded-md shadow-sm text-white bg-brand hover:bg-blue-700 transition-colors">
                    Lancer le Scan
                </button>
                <a href="/screener" class="flex-none w-[42px] h-[42px] inline-flex justify-center items-center border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" title="Réinitialiser les filtres">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                </a>
            </div>
        </form>
    </div>

    <!-- Tableau des Résultats -->
    <div class="bg-white shadow-sm border border-gray-200 rounded-xl overflow-hidden mb-8 w-full">

        <div class="px-4 sm:px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
            <h2 class="text-base sm:text-lg font-medium text-gray-900">{{ opportunities|length }} Opportunité(s) détectée(s)</h2>
        </div>

        <div class="w-full overflow-x-auto">
            <table class="w-full divide-y divide-gray-200 block sm:table">

                <thead class="bg-white hidden sm:table-header-group">
                <tr>
                    <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Date</th>
                    <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Action & Secteur</th>
                    <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Initié & Rôle</th>
                    <th class="px-4 sm:px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Valeur ($)</th>
                    <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider bg-indigo-50 border-l border-indigo-100 whitespace-nowrap">Technique (RSI)</th>
                    <th class="px-4 sm:px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Analyse</th>
                </tr>
                </thead>

                <tbody class="bg-white divide-y divide-gray-200 block sm:table-row-group">
                {% for opp in opportunities %}

                    <!-- L'ajout de min-w-0 sur tous les td résout le problème de scroll ! -->
                    <!-- L'ajout de gap-x-2 aère les colonnes mobiles -->
                    <tr class="hover:bg-gray-50 transition-colors grid grid-cols-3 sm:table-row border-b border-gray-200 sm:border-b-0 p-3 sm:p-0 gap-x-2 gap-y-3 sm:gap-y-0">

                        <!-- 1. DATE -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0 sm:whitespace-nowrap">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">Date</div>
                            <div class="text-xs sm:text-sm text-gray-900 font-medium break-words">
                                {{ opp.transaction_date|date("d/m/Y") }}
                            </div>
                        </td>

                        <!-- 2. ACTION -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0 sm:whitespace-nowrap">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">Action</div>
                            <div class="break-words">
                                <a href="/company/{{ opp.ticker }}" class="font-bold text-brand hover:underline block truncate">{{ opp.ticker }}</a>
                                <div class="text-[10px] sm:text-xs text-gray-500 mt-0.5 truncate">{{ opp.sector|default('N/A') }}</div>
                            </div>
                        </td>

                        <!-- 3. INITIÉ (Line-clamp empêche l'étalement infini vertical) -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">Initié</div>
                            <div class="break-words">
                                <a href="/insider/{{ opp.insider_id }}" class="text-brand hover:underline block truncate" title="{{ opp.insider_name }}">{{ opp.insider_name }}</a>
                                <div class="text-[10px] sm:text-xs text-gray-500 mt-0.5 truncate">{{ opp.officer_title|default('Director') }}</div>
                            </div>
                        </td>

                        <!-- 4. VALEUR -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0 sm:text-right sm:whitespace-nowrap">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">Valeur</div>
                            <div class="text-xs sm:text-sm font-bold break-words {% if opp.transaction_code == 'P' %}text-green-600{% else %}text-red-600{% endif %}">
                                {{ opp.transaction_code == 'P' ? '+' : '-' }}${{ opp.total_value|number_format(0, '.', ' ') }}
                            </div>
                        </td>

                        <!-- 5. RSI (Empilé en colonne sur mobile pour économiser la largeur) -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0 sm:text-center sm:border-l border-gray-100 sm:whitespace-nowrap">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">RSI</div>
                            <div class="flex flex-col sm:flex-row sm:inline-flex items-start sm:items-center gap-1 sm:gap-2">
                                {% if opp.rsi %}
                                    <span class="font-bold text-gray-700 text-xs sm:text-base">{{ opp.rsi|number_format(1) }}</span>
                                    {% if opp.rsi < 30 %}
                                        <span class="px-1.5 py-0.5 rounded text-[9px] sm:text-xs font-bold bg-green-100 text-green-800 self-start">Survendu</span>
                                    {% elseif opp.rsi > 70 %}
                                        <span class="px-1.5 py-0.5 rounded text-[9px] sm:text-xs font-bold bg-red-100 text-red-800 self-start">Suracheté</span>
                                    {% else %}
                                        <span class="px-1.5 py-0.5 rounded text-[9px] sm:text-xs font-bold bg-gray-100 text-gray-600 self-start">Neutre</span>
                                    {% endif %}
                                {% else %}
                                    <span class="text-[10px] sm:text-xs text-gray-400 italic">N/A</span>
                                {% endif %}
                            </div>
                        </td>

                        <!-- 6. ANALYSE -->
                        <td class="block sm:table-cell px-1 sm:px-6 py-1 sm:py-4 min-w-0 flex flex-col justify-end sm:table-cell sm:text-right sm:whitespace-nowrap">
                            <div class="text-[10px] font-bold text-gray-400 uppercase sm:hidden mb-1">Analyse</div>
                            <div>
                                <a href="/details?date={{ opp.transaction_date }}&company={{ opp.company_id }}&insider={{ opp.insider_id }}&type={{ opp.transaction_code }}"
                                   class="inline-flex items-center justify-center text-brand hover:text-blue-800 border border-blue-200 bg-blue-50 px-2 py-1.5 sm:px-3 sm:py-1.5 rounded-lg text-[10px] sm:text-sm w-full sm:w-auto text-center leading-tight">
                                    Détails&nbsp;&raquo;
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr class="block sm:table-row">
                        <td colspan="6" class="block sm:table-cell px-6 py-12 text-center text-gray-500">
                            <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Aucune transaction ne correspond à ces critères stricts.<br>Essayez d'élargir la fenêtre temporelle ou de baisser le montant minimum.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}